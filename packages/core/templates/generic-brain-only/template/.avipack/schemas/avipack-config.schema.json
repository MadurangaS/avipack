{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Avipack Config",
  "type": "object",
  "required": ["project", "brain", "bots"],
  "properties": {
    "project": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "template": { "type": "string" },
        "mode": { "type": "string", "enum": ["init", "adopt"] }
      }
    },
    "brain": {
      "type": "object",
      "required": ["root", "path"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "bots": {
      "type": "object",
      "required": ["installed", "enabled"],
      "properties": {
        "installed": { "type": "array", "items": { "type": "string" } },
        "enabled": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
